# ─────────────────────────────────────────────
# .env.example — Copy to .env and fill in values
# ─────────────────────────────────────────────

# OpenCelliD API token (free at opencellid.org/downloads.php)
OPENCELLID_TOKEN=your_token_here

# MLflow tracking server
MLFLOW_TRACKING_URI=http://localhost:5000

# Optional: Slack webhook for pipeline notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Database URL for Airflow
AIRFLOW_DB_URL=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
